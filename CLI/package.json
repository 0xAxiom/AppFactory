{
  "name": "@appfactory/cli",
  "version": "1.0.0",
  "description": "CLI for the App Factory pipeline - Generate store-ready Expo React Native apps using Claude AI",
  "main": "dist/src/index.js",
  "bin": {
    "appfactory": "./dist/src/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "start": "node dist/src/index.js",
    "smoke": "npm run build && node dist/tests/smoke.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "npm run smoke",
    "lint": "eslint src/**/*.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "expo",
    "react-native",
    "ai",
    "claude",
    "anthropic",
    "app-generator",
    "mobile-app"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "ajv": "^8.17.1",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "inquirer": "^13.3.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
